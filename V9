<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="no-referrer">
<title>Apple Watch Series 11 — Apple (India)</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg-dark:#000000;
  --bg-mid:#1d1d1f;
  --bg-light:#f5f5f7;
  --bg-white:#ffffff;
  --text-dark:#1d1d1f;
  --text-light:#f5f5f7;
  --text-muted:#86868b;
  --blue:#2250CE;
  --blue-hover:#1a40b0;
  --green:#30d158;
  --red:#ff3b30;
  --font:-apple-system,"SF Pro Display","SF Pro Text","Helvetica Neue",Arial,sans-serif;
}

html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg-white);color:var(--text-dark);-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* ── GLOBAL NAV ───────────────────────────────────────── */
.gnav{
  height:52px;
  background:#fff;
  border-bottom:1px solid rgba(0,0,0,0.08);
  display:flex;align-items:center;justify-content:center;
}
.gnav-inner{
  max-width:1440px;width:100%;padding:0 32px;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
}
.gnav-logo{font-size:15px;font-weight:700;letter-spacing:-.02em;color:var(--text-dark);text-decoration:none;white-space:nowrap;flex-shrink:0}
.gnav-logo sup{font-size:9px;vertical-align:super;line-height:0}
.gnav-links{display:flex;gap:2px;list-style:none;align-items:center}
.gnav-links a{font-size:12px;color:var(--text-dark);text-decoration:none;padding:6px 9px;border-radius:8px;opacity:0.72;transition:opacity .15s,background .15s;white-space:nowrap}
.gnav-links a:hover{opacity:1;background:rgba(0,0,0,0.05)}
.gnav-icons{display:flex;align-items:center;gap:4px;flex-shrink:0}
.gnav-icon-btn{display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;color:var(--text-dark);text-decoration:none;opacity:0.72;transition:opacity .15s,background .15s}
.gnav-icon-btn:hover{opacity:1;background:rgba(0,0,0,0.06)}

/* ── PROMO BAR ───────────────────────────────────────── */
.promo-bar{
  position:relative;
  background:#2250CE;
  height:40px;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}
.promo-bar::before,.promo-bar::after{
  content:'';position:absolute;top:0;bottom:0;width:140px;pointer-events:none;z-index:1;
}
.promo-bar::before{left:0;background:linear-gradient(to right,#fff,transparent)}
.promo-bar::after{right:0;background:linear-gradient(to left,#fff,transparent)}
.promo-bar-text{
  font-size:13px;font-weight:500;color:#fff;letter-spacing:.01em;position:relative;z-index:2;
}
.promo-bar-text strong{font-weight:700;}

/* ── HERO · MacBook Air "Might takes flight" style ─────── */
#hero{
  background:var(--bg-white);
  min-height:100vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:120px 24px 80px;
  position:relative;overflow:hidden;
}
.hero-glow{
  position:absolute;width:800px;height:800px;
  background:radial-gradient(ellipse,rgba(255,64,129,0.07) 0%,rgba(124,77,255,0.05) 45%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-55%);
  pointer-events:none;
}
.hero-eyebrow{
  font-size:13px;font-weight:600;color:var(--text-muted);
  letter-spacing:0.08em;text-transform:uppercase;
  margin-bottom:18px;
  opacity:0;animation:fadeUp .9s .15s forwards;
}
.hero-headline{
  font-size:clamp(60px,9.5vw,100px);font-weight:800;
  color:var(--text-dark);letter-spacing:-0.03em;
  line-height:0.98;max-width:10ch;margin:0 auto 24px;
  opacity:0;animation:fadeUp .9s .3s forwards;
}
.hero-sub{
  font-size:clamp(17px,2vw,21px);font-weight:300;
  color:var(--text-muted);max-width:42ch;margin:0 auto 28px;
  line-height:1.65;
  opacity:0;animation:fadeUp .9s .45s forwards;
}
.hero-price{
  font-size:17px;color:var(--text-muted);
  margin-bottom:32px;
  opacity:0;animation:fadeUp .9s .55s forwards;
}
.hero-ctas{
  display:flex;gap:16px;justify-content:center;flex-wrap:wrap;
  margin-bottom:80px;
  opacity:0;animation:fadeUp .9s .65s forwards;
}

/* ── SONIC BRUSH Kids illustration ─────────────────────── */
.brush-stage{
  position:relative;margin-bottom:60px;
  opacity:0;animation:brushDrop 1.1s .05s cubic-bezier(0.16,1,0.3,1) forwards;
}
@keyframes brushDrop{
  from{opacity:0;transform:translateY(-28px) scale(0.93)}
  to{opacity:1;transform:translateY(0) scale(1)}
}
.brush{
  width:80px;margin:0 auto;position:relative;
  filter:drop-shadow(0 36px 72px rgba(255,64,129,0.22)) drop-shadow(0 10px 28px rgba(0,0,0,0.08));
}
.b-head{
  width:80px;height:94px;background:#fff;
  border-radius:20px 20px 6px 6px;
  border:1.5px solid #eee;
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;padding:8px 10px;gap:5px;
}
.b-row{display:flex;gap:4px;justify-content:center}
.b-tuft{width:13px;border-radius:6px}
.b-row:nth-child(1) .b-tuft{height:22px}
.b-row:nth-child(1) .b-tuft:nth-child(1){background:linear-gradient(to top,#ff6b9d,#c44cff)}
.b-row:nth-child(1) .b-tuft:nth-child(2){background:linear-gradient(to top,#4facfe,#00f2fe)}
.b-row:nth-child(1) .b-tuft:nth-child(3){background:linear-gradient(to top,#43e97b,#38f9d7)}
.b-row:nth-child(1) .b-tuft:nth-child(4){background:linear-gradient(to top,#f6d365,#fda085)}
.b-row:nth-child(2) .b-tuft{height:16px}
.b-row:nth-child(2) .b-tuft:nth-child(1){background:linear-gradient(to top,#4facfe,#00f2fe)}
.b-row:nth-child(2) .b-tuft:nth-child(2){background:linear-gradient(to top,#ff6b9d,#c44cff)}
.b-row:nth-child(2) .b-tuft:nth-child(3){background:linear-gradient(to top,#f6d365,#fda085)}
.b-row:nth-child(2) .b-tuft:nth-child(4){background:linear-gradient(to top,#43e97b,#38f9d7)}
.b-neck{
  width:20px;height:26px;
  background:linear-gradient(to bottom,#f5f5f7,#ff4081);
  margin:0 auto;
}
.b-handle{
  width:80px;height:210px;
  background:linear-gradient(168deg,#ff8a80 0%,#ff4081 32%,#7c4dff 68%,#5200ea 100%);
  border-radius:20px;position:relative;
  display:flex;flex-direction:column;align-items:center;
  padding-top:30px;gap:14px;
}
.b-handle::before{
  content:'';position:absolute;left:11px;top:14px;
  width:14px;height:54px;border-radius:7px;
  background:linear-gradient(to bottom,rgba(255,255,255,0.28),rgba(255,255,255,0));
}
.b-btn{
  width:38px;height:38px;border-radius:50%;
  background:rgba(255,255,255,0.16);
  border:2px solid rgba(255,255,255,0.32);
  position:relative;
}
.b-btn::after{
  content:'';position:absolute;width:12px;height:12px;
  border-radius:50%;background:rgba(255,255,255,0.9);
  top:50%;left:50%;transform:translate(-50%,-50%);
}
.b-ribs{display:flex;flex-direction:column;gap:7px}
.b-rib{width:36px;height:4px;background:rgba(255,255,255,0.14);border-radius:2px}
.b-brand{
  position:absolute;bottom:22px;
  font-size:8px;font-weight:800;letter-spacing:.14em;
  color:rgba(255,255,255,0.4);text-transform:uppercase;
}
.b-pulse{
  position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);
  width:80px;height:80px;pointer-events:none;
}
.b-ring{
  position:absolute;inset:0;border-radius:50%;
  border:1.5px solid rgba(255,64,129,0.3);
  animation:bRing 2.4s ease-out infinite;
}
.b-ring:nth-child(2){animation-delay:.8s}
.b-ring:nth-child(3){animation-delay:1.6s}
@keyframes bRing{
  0%{transform:scale(.5);opacity:.7}
  100%{transform:scale(2.8);opacity:0}
}
.btn-primary{
  background:var(--blue);color:white;border:none;
  padding:12px 26px;border-radius:980px;font-size:17px;
  font-family:var(--font);cursor:pointer;text-decoration:none;
  display:inline-block;transition:background .2s;
}
.btn-primary:hover{background:var(--blue-hover)}
.btn-ghost{
  background:transparent;color:var(--blue);border:none;
  padding:12px 26px;border-radius:980px;font-size:17px;
  font-family:var(--font);cursor:pointer;text-decoration:none;
  display:inline-block;transition:opacity .2s;
}
.btn-ghost:hover{opacity:.7}

/* Watch CSS component */
.watch-stage{
  position:relative;display:inline-block;
  opacity:0;animation:watchDrop 1.1s .05s cubic-bezier(0.16,1,0.3,1) forwards;
  margin-bottom:60px;
}
@keyframes watchDrop{
  from{opacity:0;transform:translateY(-24px) scale(0.94)}
  to{opacity:1;transform:translateY(0) scale(1)}
}
.watch-device{
  width:190px;height:228px;
  background:linear-gradient(145deg,#3a3a3a,#111);
  border-radius:54px;position:relative;
  box-shadow:0 0 0 1.5px rgba(255,255,255,0.18),
             0 70px 140px rgba(0,0,0,0.9),
             0 20px 40px rgba(0,0,0,0.5);
  transition:background .5s,box-shadow .5s;
}
.watch-screen{
  position:absolute;inset:10px;background:#000;
  border-radius:44px;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.watch-face{text-align:center;color:white;padding:10px;}
.watch-time{font-size:46px;font-weight:200;letter-spacing:-2px;line-height:1}
.watch-date{font-size:10px;color:rgba(255,255,255,0.5);letter-spacing:.1em;text-transform:uppercase;margin-top:3px}
.watch-comps{display:flex;gap:10px;margin-top:16px;justify-content:center}
.watch-comp{
  width:38px;height:38px;background:rgba(255,255,255,0.08);
  border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;
}
.watch-crown{
  position:absolute;right:-11px;top:50%;transform:translateY(-50%);
  width:11px;height:52px;background:inherit;border-radius:6px;
  box-shadow:0 0 0 1px rgba(255,255,255,0.1);
}
.watch-band-t,.watch-band-b{
  position:absolute;left:16px;right:16px;height:100px;
  background:linear-gradient(to bottom,#1a1a1e,#0e0e10);
}
.watch-band-t{bottom:100%;border-radius:6px 6px 0 0;margin-bottom:-1px}
.watch-band-b{top:100%;border-radius:0 0 6px 6px;margin-top:-1px;background:linear-gradient(to bottom,#111,#090909)}

@keyframes fadeUp{
  from{opacity:0;transform:translateY(22px)}
  to{opacity:1;transform:translateY(0)}
}

/* ── HIGHLIGHTS STRIP ─────────────────────────────────── */
#highlights{
  background:var(--bg-dark);
  border-top:1px solid rgba(255,255,255,0.07);
}
.highlights-grid{
  max-width:1020px;margin:0 auto;padding:0 22px;
  display:grid;grid-template-columns:repeat(4,1fr);
}
.hl-item{
  padding:44px 28px;
  border-right:1px solid rgba(255,255,255,0.07);
}
.hl-item:last-child{border-right:none}
.hl-icon{font-size:32px;margin-bottom:14px;display:block}
.hl-title{font-size:14px;font-weight:600;color:var(--text-light);line-height:1.35;margin-bottom:8px}
.hl-desc{font-size:12px;color:var(--text-muted);line-height:1.55}

/* ── SECTION SHELL ────────────────────────────────────── */
.section{padding:120px 24px}
.section-inner{max-width:980px;margin:0 auto}
.eyebrow{font-size:15px;font-weight:600;color:var(--text-muted);margin-bottom:10px}
.headline{
  font-size:clamp(36px,5.5vw,60px);font-weight:700;
  letter-spacing:-0.003em;line-height:1.06;margin-bottom:20px;
}
.body-copy{font-size:19px;font-weight:300;line-height:1.65;color:var(--text-muted);max-width:560px}

/* Dark section overrides */
.dark{background:var(--bg-dark);color:var(--text-light)}
.dark .eyebrow{color:#2997ff}
.dark .body-copy{color:rgba(245,245,247,0.55)}

/* Light gray section */
.gray{background:var(--bg-light)}

/* ── HEALTH ───────────────────────────────────────────── */
.health-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:60px}
.hcard{
  background:#1d1d1f;border-radius:28px;padding:48px 44px;
  position:relative;overflow:hidden;
}
.hcard.wide{grid-column:span 2}
.hcard-chip{
  display:inline-block;font-size:11px;font-weight:700;
  color:#2997ff;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px;
}
.hcard-headline{
  font-size:clamp(22px,2.8vw,30px);font-weight:700;
  color:var(--text-light);letter-spacing:-0.015em;line-height:1.18;margin-bottom:14px;
}
.hcard-body{font-size:15px;line-height:1.65;color:rgba(245,245,247,0.55);max-width:380px}

/* Notification pill */
.notif-pill{
  margin-top:36px;background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.08);border-radius:18px;
  padding:18px 22px;display:inline-flex;gap:14px;align-items:flex-start;max-width:360px;
}
.notif-dot{
  width:38px;height:38px;background:var(--red);border-radius:10px;
  flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;
}
.notif-strong{display:block;font-size:13px;font-weight:600;color:var(--text-light);margin-bottom:4px}
.notif-desc{font-size:12px;color:rgba(245,245,247,0.45);line-height:1.5}

/* Sleep ring */
.sleep-row{display:flex;align-items:center;gap:22px;margin-top:36px}
.sleep-ring{
  width:84px;height:84px;border-radius:50%;flex-shrink:0;
  background:conic-gradient(var(--green) 0% 82%,rgba(255,255,255,0.08) 82% 100%);
  display:flex;align-items:center;justify-content:center;position:relative;
}
.sleep-ring::after{content:'';position:absolute;inset:9px;background:#1d1d1f;border-radius:50%}
.sleep-val{position:relative;z-index:1;font-size:24px;font-weight:700;color:white}
.sleep-info{color:rgba(245,245,247,0.55);font-size:14px;line-height:1.6}
.sleep-info strong{display:block;color:var(--text-light);font-size:18px;font-weight:600;margin-bottom:2px}

/* ECG / BloodO2 row */
.health-metrics{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:40px}
.metric-card{
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);
  border-radius:16px;padding:22px 24px;
}
.mc-chip{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
.mc-value{font-size:40px;font-weight:700;color:white;letter-spacing:-1.5px;line-height:1}
.mc-sub{font-size:12px;color:rgba(245,245,247,0.4);margin-top:4px}
.ecg-svg{width:100%;height:28px;margin-top:12px;overflow:visible}

/* ── COLOR PICKER ─────────────────────────────────────── */
.color-pick-wrap{text-align:center}
.swatches{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin:52px auto 16px}
.swatch{
  width:30px;height:30px;border-radius:50%;cursor:pointer;
  border:2px solid transparent;outline:3px solid transparent;
  transition:transform .2s,outline-color .2s;position:relative;
}
.swatch::after{content:'';position:absolute;inset:2px;border-radius:50%;background:var(--c)}
.swatch:hover{transform:scale(1.18)}
.swatch.on{outline-color:var(--text-dark);transform:scale(1.12)}
.color-label{font-size:15px;color:var(--text-muted);height:24px;transition:opacity .2s;margin-bottom:48px}
.watch-showcase-wrap{display:flex;justify-content:center;perspective:900px}
.watch-showcase-inner{transition:transform .5s cubic-bezier(0.34,1.56,0.64,1)}

/* ── SPLIT LAYOUT ─────────────────────────────────────── */
.split{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.split.rev{direction:rtl}
.split.rev>*{direction:ltr}
.split-visual{
  border-radius:28px;overflow:hidden;
  aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;
}

/* fitness visual */
.fitness-watch{
  width:164px;height:196px;
  background:linear-gradient(145deg,#2a2a2e,#111);
  border-radius:46px;position:relative;
  box-shadow:0 0 0 1.5px rgba(255,255,255,0.1),0 40px 80px rgba(0,0,0,0.8);
}
.fitness-screen{
  position:absolute;inset:9px;background:#000;
  border-radius:38px;display:flex;align-items:center;
  justify-content:center;flex-direction:column;gap:4px;text-align:center;
}

/* ── BATTERY ──────────────────────────────────────────── */
.battery-vis{background:#1d1d1f;display:flex;align-items:center;justify-content:center;min-height:340px}
.batt-inner{text-align:center}
.batt-pct{font-size:96px;font-weight:700;color:var(--green);letter-spacing:-4px;line-height:.9}
.batt-unit{font-size:22px;font-weight:400;color:rgba(245,245,247,0.45)}
.batt-label{font-size:14px;color:rgba(245,245,247,0.35);margin-top:6px;text-transform:uppercase;letter-spacing:.06em}
.batt-bar{width:180px;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;margin:20px auto 0}
.batt-fill{height:100%;background:var(--green);border-radius:4px;width:0%;animation:fillBatt 1.8s 1s ease-out forwards}
@keyframes fillBatt{to{width:63%}} /* 38/60 ≈ 63% relative to max */

/* stat row */
.stat-row{display:flex;gap:40px;margin-top:36px;flex-wrap:wrap}
.stat-item{display:flex;flex-direction:column;gap:4px}
.stat-num{font-size:44px;font-weight:700;letter-spacing:-1.5px;line-height:1;color:var(--text-dark)}
.stat-desc{font-size:13px;color:var(--text-muted)}

/* ── CONNECTIVITY ─────────────────────────────────────── */
.conn-center{text-align:center}
.conn-center .body-copy{margin:0 auto}
.signal{display:flex;gap:7px;align-items:flex-end;justify-content:center;height:64px;margin:48px auto 20px}
.sig-bar{
  width:22px;background:rgba(255,255,255,0.12);border-radius:4px;
  animation:barGrow .5s ease-out both;
}
.sig-bar.lit{background:#2997ff}
.sig-bar:nth-child(1){height:16%;animation-delay:.2s}
.sig-bar:nth-child(2){height:36%;animation-delay:.32s}
.sig-bar:nth-child(3){height:58%;animation-delay:.44s}
.sig-bar:nth-child(4){height:78%;animation-delay:.56s}
.sig-bar:nth-child(5){height:100%;animation-delay:.68s}
@keyframes barGrow{from{opacity:.2;transform:scaleY(.5)}to{opacity:1;transform:scaleY(1)}}
.fiveg-badge{
  font-size:14px;font-weight:700;letter-spacing:.05em;
  color:#2997ff;margin-bottom:48px;
}
.conn-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:720px;margin:0 auto}
.conn-card{
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);
  border-radius:18px;padding:30px 22px;text-align:center;
}
.conn-card-icon{font-size:32px;margin-bottom:14px}
.conn-card-title{font-size:15px;font-weight:600;color:var(--text-light);margin-bottom:8px}
.conn-card-desc{font-size:13px;color:rgba(245,245,247,0.4);line-height:1.55}

/* ── SAFETY ───────────────────────────────────────────── */
.safety-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
.safety-card{background:white;border-radius:22px;padding:38px 30px}
.safety-icon{font-size:36px;margin-bottom:18px}
.safety-title{font-size:19px;font-weight:600;letter-spacing:-0.01em;margin-bottom:10px}
.safety-desc{font-size:15px;color:var(--text-muted);line-height:1.6}
.water-strip{
  margin-top:16px;background:white;border-radius:20px;
  padding:28px 32px;display:flex;align-items:center;gap:24px;
}
.water-strip-icon{font-size:40px;flex-shrink:0}
.water-title{font-size:17px;font-weight:600;color:var(--text-dark);margin-bottom:4px}
.water-desc{font-size:15px;color:var(--text-muted)}

/* ── BUY ──────────────────────────────────────────────── */
#buy{text-align:center;border-top:1px solid rgba(0,0,0,0.07);padding:110px 24px 100px}
#buy .body-copy{margin:0 auto}
.buy-price{font-size:19px;color:var(--text-muted);margin:16px 0 32px}
.buy-ctas{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:80px}

/* ── SPECS TABLE ──────────────────────────────────────── */
.specs-table{
  border-top:1px solid rgba(0,0,0,0.08);padding-top:60px;text-align:left;
  max-width:860px;margin:0 auto;
}
.specs-title{font-size:24px;font-weight:600;letter-spacing:-0.01em;margin-bottom:32px}
