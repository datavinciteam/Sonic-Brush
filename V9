/* ── Spiel scroll-reveal ──────────────────────────────── */
document.addEventListener('DOMContentLoaded', function() {
  const p = document.querySelector('.spiel-text');
  if (!p) return;
  function wrapTextNode(node) {
    const parts = node.textContent.split(/(\s+)/);
    const frag = document.createDocumentFragment();
    parts.forEach(function(part) {
      if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); }
      else if (part) { const s = document.createElement('span'); s.className = 'spiel-word'; s.textContent = part; frag.appendChild(s); }
    });
    node.parentNode.replaceChild(frag, node);
  }
  function processNode(node) {
    Array.from(node.childNodes).forEach(function(child) {
      if (child.nodeType === 3) wrapTextNode(child);
      else if (child.nodeType === 1) processNode(child);
    });
  }
  processNode(p);
  const spans = p.querySelectorAll('.spiel-word');
  function revealSpiel() {
    const threshold = window.innerHeight * 0.82;
    spans.forEach(function(s) {
      if (s.getBoundingClientRect().top < threshold) s.classList.add('on');
      else s.classList.remove('on');
    });
  }
  window.addEventListener('scroll', revealSpiel, { passive: true });
  revealSpiel();
});

/* ── Features sticky-scroll ──────────────────────────── */
(function() {
  const section = document.getElementById('featScroll');
  if (!section) return;
  const texts = section.querySelectorAll('.fs-text');
  const imgs  = section.querySelectorAll('.fs-img');
  const N = texts.length;
  let fsTotalPanels = 4;
  let cur = -1;
  function setActive(i) {
    if (i === cur) return;
    cur = i;
    texts.forEach(function(t, idx) { t.classList.toggle('fs-on', idx === i); });
    imgs.forEach(function(img, idx) { img.classList.toggle('fs-on', idx === i); });
  }
  function onScroll() {
    if (window.innerWidth <= 768) return;
    const rect = section.getBoundingClientRect();
    const progress = -rect.top / (section.offsetHeight - window.innerHeight);
    setActive(Math.min(N - 1, Math.max(0, Math.floor(progress * N))));
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();

/* ── Comparison card carousel (swipe left = advance, next peeks right) ── */
(function(){
  var CMP_N = 10;
  var cmpCur = 0, cmpTimer = null, cmpT = 0, _cd = false, _sx = 0;

  function cmpDims(){
    var o = document.getElementById('cmpCarOuter'); if(!o) return null;
    var ow = o.offsetWidth;
    var sw = window.innerWidth<=480 ? Math.round(ow*0.86) : window.innerWidth<=768 ? Math.round(ow*0.56) : Math.round(ow*0.26);
    return {ow:ow, sw:sw, gap:Math.round(ow*0.02), peekOff:0};
  }

  function cmpLayout(){
    var d = cmpDims(), t = document.getElementById('cmpCarTrack'); if(!d||!t) return;
    t.style.gap = d.gap+'px';
    t.querySelectorAll('.cc-slide').forEach(function(s){ s.style.width = d.sw+'px'; });
  }

  function cmpCommit(n, T, d, instant){
    var t = document.getElementById('cmpCarTrack'); if(!t) return;
    var trackW = CMP_N*d.sw + (CMP_N-1)*d.gap;
    var minT = d.ow - trackW;
    cmpCur = n; cmpT = T;
    if(instant){ t.style.transition='none'; t.style.transform='translateX('+T+'px)'; requestAnimationFrame(function(){ t.style.transition=''; }); }
    else t.style.transform='translateX('+T+'px)';
    document.querySelectorAll('.cc-dot').forEach(function(el,i){ el.classList.toggle('on', i===n); });
    var prevBtn = document.getElementById('cmpPrev'), nextBtn = document.getElementById('cmpNext');
    if(prevBtn) prevBtn.disabled = T >= d.peekOff;
    if(nextBtn) nextBtn.disabled = T <= minT;
    clearTimeout(cmpTimer);
    if(T > minT) cmpTimer = setTimeout(function(){ cmpGoCard(cmpCur+1); }, 4800);
  }

  /* Jump to a specific card index (used by dots and auto-advance) */
  function cmpGoCard(n, instant){
    n = Math.max(0, Math.min(CMP_N-1, n));
    var d = cmpDims(); if(!d) return;
    var trackW = CMP_N*d.sw + (CMP_N-1)*d.gap;
    var T = Math.max(d.ow - trackW, Math.min(d.peekOff, d.peekOff - n*(d.sw+d.gap)));
    cmpCommit(n, T, d, instant);
  }

  /* Step by one card-width from the current pixel offset (used by arrows and swipe).
     dir = -1 → left (advance), +1 → right (back). */
  function cmpStep(dir){
    var d = cmpDims(); if(!d) return;
    var trackW = CMP_N*d.sw + (CMP_N-1)*d.gap;
    var minT = d.ow - trackW;
    var T = Math.max(minT, Math.min(d.peekOff, cmpT + dir*(d.sw+d.gap)));
    var n = Math.max(0, Math.min(CMP_N-1, Math.round((d.peekOff - T) / (d.sw+d.gap))));
    cmpCommit(n, T, d, false);
  }

  window.cmpGo = cmpGoCard;

  document.addEventListener('DOMContentLoaded', function(){
    var outer = document.getElementById('cmpCarOuter'); if(!outer) return;
    cmpLayout();
    var dotsEl = document.getElementById('cmpDots');
    if(dotsEl){ for(var i=0;i<CMP_N;i++){ var b=document.createElement('button'); b.className='cc-dot'; b.setAttribute('aria-label','Go to card '+(i+1)); (function(idx){ b.onclick=function(){ cmpGoCard(idx); }; })(i); dotsEl.appendChild(b); } }
    cmpGoCard(0, true);
    outer.addEventListener('touchstart', function(e){ _sx=e.touches[0].clientX; _cd=true; }, {passive:true});
    outer.addEventListener('touchend', function(e){ if(!_cd)return; _cd=false; var dx=e.changedTouches[0].clientX-_sx; if(Math.abs(dx)>48) cmpStep(dx<0?-1:1); }, {passive:true});
    outer.addEventListener('mousedown', function(e){ _sx=e.clientX; _cd=true; });
    outer.addEventListener('mouseup', function(e){ if(!_cd)return; _cd=false; var dx=e.clientX-_sx; if(Math.abs(dx)>48) cmpStep(dx<0?-1:1); });
    outer.addEventListener('mouseleave', function(){ _cd=false; });
    var prev = document.getElementById('cmpPrev'); if(prev) prev.onclick = function(){ cmpStep(1); };
    var next = document.getElementById('cmpNext'); if(next) next.onclick = function(){ cmpStep(-1); };
    window.addEventListener('resize', function(){ cmpLayout(); cmpGo(cmpCur,true); }, {passive:true});
  });
})();

/* ── Rebuttals carousel ──────────────────────────────── */
(function(){
  var RB_N = 10;
  var rbCur = 0, rbTimer = null, _rd = false, _rx = 0;

  function rbDims(){
    var o = document.getElementById('rbCarOuter'); if(!o) return null;
    var ow = o.offsetWidth;
    var sw = window.innerWidth<=480 ? Math.round(ow*0.86) : window.innerWidth<=768 ? Math.round(ow*0.50) : Math.round(ow*0.22);
    return {ow:ow, sw:sw, gap:Math.round(ow*0.018), peekOff:Math.round(ow*0.02)};
  }

  function rbLayout(){
    var d = rbDims(), t = document.getElementById('rbCarTrack'); if(!d||!t) return;
    t.style.gap = d.gap+'px';
    t.querySelectorAll('.rb-slide').forEach(function(s){ s.style.width = d.sw+'px'; });
  }

  window.rbGo = function(n, instant){
    clearTimeout(rbTimer);
    rbCur = Math.max(0, Math.min(RB_N - 1, n));
    var d = rbDims(), t = document.getElementById('rbCarTrack'); if(!d||!t) return;
    var T = d.peekOff - rbCur*(d.sw+d.gap);
    var trackW = RB_N*d.sw + (RB_N-1)*d.gap;
    T = Math.max(T, d.ow - trackW);
    if(instant){ t.style.transition='none'; t.style.transform='translateX('+T+'px)'; requestAnimationFrame(function(){ t.style.transition=''; }); }
    else t.style.transform='translateX('+T+'px)';
    document.querySelectorAll('.rb-dot').forEach(function(el,i){ el.classList.toggle('on', i===rbCur); });
    if(rbCur < RB_N - 1) rbTimer = setTimeout(function(){ rbGo(rbCur+1); }, 5000);
  };

  document.addEventListener('DOMContentLoaded', function(){
    var outer = document.getElementById('rbCarOuter'); if(!outer) return;
    rbLayout();
    var dotsEl = document.getElementById('rbDots');
    if(dotsEl){ for(var i=0;i<RB_N;i++){ var b=document.createElement('button'); b.className='rb-dot'; b.setAttribute('aria-label','Go to card '+(i+1)); (function(idx){ b.onclick=function(){ rbGo(idx); }; })(i); dotsEl.appendChild(b); } }
    rbGo(0, true);
    var prev = document.getElementById('rbPrev'); if(prev) prev.onclick = function(){ rbGo(rbCur-1); };
    var next = document.getElementById('rbNext'); if(next) next.onclick = function(){ rbGo(rbCur+1); };
    outer.addEventListener('touchstart', function(e){ _rx=e.touches[0].clientX; _rd=true; }, {passive:true});
    outer.addEventListener('touchend', function(e){ if(!_rd)return; _rd=false; var dx=e.changedTouches[0].clientX-_rx; if(Math.abs(dx)>48) rbGo(rbCur+(dx<0?1:-1)); }, {passive:true});
    outer.addEventListener('mousedown', function(e){ _rx=e.clientX; _rd=true; });
    outer.addEventListener('mouseup', function(e){ if(!_rd)return; _rd=false; var dx=e.clientX-_rx; if(Math.abs(dx)>48) rbGo(rbCur+(dx<0?1:-1)); });
    outer.addEventListener('mouseleave', function(){ _rd=false; });
    window.addEventListener('resize', function(){ rbLayout(); rbGo(rbCur,true); }, {passive:true});
  });
})();

