<script>
/* ── Color Picker ─────────────────────────────────────── */
function pickColor(btn) {
  document.querySelectorAll('.swatch').forEach(s => s.classList.remove('on'));
  btn.classList.add('on');

  const watch = document.getElementById('showcaseWatch');
  const tilt  = document.getElementById('showcaseTilt');
  const label = document.getElementById('colorLabel');

  label.style.opacity = '0';
  setTimeout(() => {
    label.textContent   = btn.dataset.name;
    label.style.opacity = '1';
  }, 160);

  watch.style.background = btn.dataset.bg;
  watch.style.boxShadow  = btn.dataset.shadow;
  // Crown matches case
  const crown = watch.querySelector('.watch-crown');
  if (crown) crown.style.background = btn.dataset.bg;

  // Subtle tilt pop
  tilt.style.transition = 'transform .12s ease';
  tilt.style.transform  = 'rotateY(12deg) rotateX(-6deg) scale(1.06)';
  setTimeout(() => {
    tilt.style.transition = 'transform .7s cubic-bezier(0.34,1.56,0.64,1)';
    tilt.style.transform  = 'rotateY(-10deg) rotateX(5deg) scale(1)';
  }, 120);
}

/* ── Scroll Reveal ────────────────────────────────────── */
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); revealObs.unobserve(e.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -32px 0px' });

document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

/* ── Local Nav Active Link ────────────────────────────── */
const navAnchors = Array.from(document.querySelectorAll('.lnav-links a'));
const sectionIds = navAnchors.map(a => a.getAttribute('href').slice(1));

const activeObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navAnchors.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + e.target.id));
    }
  });
}, { threshold: 0.35 });

sectionIds.forEach(id => { const el = document.getElementById(id); if (el) activeObs.observe(el); });

/* ── IMAGE CAROUSEL ──────────────────────────────────── */
let carCur = 0;
const CAR_N = 8;
let carPlaying = false;
let carTimer = null;

function carDims() {
  const outer = document.getElementById('carOuter');
  if (!outer) return null;
  const ow = outer.offsetWidth;
  if (!ow) return null;
  const swRatio = window.innerWidth <= 480 ? 0.94 : window.innerWidth <= 900 ? 0.88 : 0.55;
  return { ow, sw: Math.round(ow * swRatio), gap: Math.round(ow * 0.03), peekOff: Math.round(ow * 0.10) };
}

function carLayout() {
  const d = carDims();
  const track = document.getElementById('carTrack');
  if (!d || !track) return;
  track.style.gap = d.gap + 'px';
  track.querySelectorAll('.car-slide').forEach(s => s.style.width = d.sw + 'px');
}

function carGo(n, instant) {
  clearTimeout(carTimer);
  carCur = Math.max(0, Math.min(CAR_N - 1, n));
  const d = carDims();
  const track = document.getElementById('carTrack');
  if (d && track) {
    const T = (d.ow - d.sw) - (CAR_N - 1 - carCur) * (d.sw + d.gap);
    if (instant) { track.style.transition = 'none'; track.style.transform = 'translateX(' + T + 'px)'; track.offsetHeight; track.style.transition = ''; }
    else { track.style.transform = 'translateX(' + T + 'px)'; }
  }
  document.querySelectorAll('.car-dot').forEach((el, i) => el.classList.toggle('on', i === carCur));
  if (carPlaying && carCur < CAR_N - 1) carTimer = setTimeout(() => carGo(carCur + 1), 4500);
}

function carTogglePlay() {
  carPlaying = !carPlaying;
  const btn = document.getElementById('carPP');
  if (btn) btn.innerHTML = carPlaying ? '&#9646;&#9646;' : '&#9654;';
  if (carPlaying) carGo(carCur + 1); else clearTimeout(carTimer);
}

/* Touch / drag */
(function() {
  let sx = 0, dragging = false;
  function start(x) { sx = x; dragging = true; }
  function end(x) { if (!dragging) return; dragging = false; if (Math.abs(x - sx) > 40) carGo(carCur + (x > sx ? 1 : -1)); }
  const track = document.getElementById('carTrack');
  if (track) {
    track.addEventListener('mousedown', e => start(e.clientX));
    document.addEventListener('mouseup', e => end(e.clientX));
    track.addEventListener('touchstart', e => start(e.touches[0].clientX), { passive: true });
    track.addEventListener('touchend', e => end(e.changedTouches[0].clientX), { passive: true });
  }
})();

// Color — updates all carousel watches + syncs design-section picker
function tfPickColor(btn) {
  document.querySelectorAll('.tf-c').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('tfColorName').textContent = '— ' + btn.dataset.cname;

  const bg = btn.dataset.cbg, sh = btn.dataset.cshadow, bt = btn.dataset.cbt, bb = btn.dataset.cbb;

  // Carousel car-watch shells
  document.querySelectorAll('.car-watch').forEach(w => {
    w.style.background = bg; w.style.boxShadow = sh;
    const cr = w.querySelector('.car-crown'); if (cr) cr.style.background = bg;
    const bbt = w.querySelector('.car-bt');   if (bbt) bbt.style.background = bt;
    const bbb = w.querySelector('.car-bb');   if (bbb) bbb.style.background = bb;
  });
  // Back-of-watch slide
  const bk = document.getElementById('cw4back');
  if (bk) { bk.style.background = bg; bk.style.boxShadow = sh; }

  // Sync existing design-section swatch picker
  const match = document.querySelector(`.swatch[title="${btn.dataset.cname}"]`);
  if (match) pickColor(match);

  tfUpdateSummary();
}

// Size
let tfSizeExtra = 0;
function tfPickSize(btn) {
  document.querySelectorAll('#tfSizeSegs .tf-seg').forEach(s => s.classList.remove('on'));
  btn.classList.add('on');
  tfSizeExtra = btn.dataset.size === '46' ? 3000 : 0;
  document.getElementById('tfSizeName').textContent = '— ' + btn.dataset.size + 'mm';
  tfUpdatePrice(); tfUpdateSummary();
}

// Material
let tfMatExtra = 0;
function tfPickMat(btn) {
  document.querySelectorAll('#tfMatSegs .tf-seg').forEach(s => s.classList.remove('on'));
