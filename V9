}
.tf-pill-ic svg{stroke:#2250CE;width:22px;height:22px;display:block}
.tf-pill{
  color:var(--text-dark);
  font-size:17px;font-weight:400;
  line-height:1.45;letter-spacing:-0.01em;
  min-width:0;flex:1;
}
.tf-pill-row{gap:12px;margin:12px 0}
.tf-tg{background:linear-gradient(135deg,#2250CE 0%,#1355B0 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:inline-block}
.tf-rating-row{display:flex;align-items:center;gap:8px;margin-bottom:20px}
.tf-stars{color:#ff9500;font-size:14px}
.tf-rlink{font-size:13px;color:var(--blue);text-decoration:none;cursor:pointer}
.tf-price-from{font-size:15px;color:var(--text-muted);font-weight:400}
.tf-price-num{font-size:30px;font-weight:700;letter-spacing:-1px;color:var(--text-dark)}
.tf-emi{font-size:13px;color:var(--blue);cursor:pointer;margin:6px 0 22px;display:block;text-decoration:none}
.tf-div{height:1px;background:rgba(0,0,0,0.08);margin:20px 0}
/* Option group */
.tf-og{margin-bottom:22px}
.tf-og-lbl{font-size:13px;margin-bottom:12px}
.tf-og-lbl b{font-weight:600;color:var(--text-dark)}
.tf-og-lbl em{font-style:normal;color:var(--text-muted)}
/* Color chips */
.tf-cc{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.tf-c{width:28px;height:28px;border-radius:50%;cursor:pointer;border:2px solid transparent;outline:2.5px solid transparent;outline-offset:2px;position:relative;transition:outline-color .18s,transform .15s;background:none}
.tf-c::after{content:'';position:absolute;inset:2px;border-radius:50%;background:var(--cc)}
.tf-c:hover{transform:scale(1.15)}
.tf-c.on{outline-color:var(--text-dark)}
.tf-cc-sep{width:1px;height:24px;background:rgba(0,0,0,0.1);flex-shrink:0;border-radius:1px}
/* Segments */
.tf-segs{display:flex;border:1.5px solid rgba(0,0,0,0.14);border-radius:10px;overflow:hidden}
.tf-seg{flex:1;padding:10px 12px;font-size:13px;font-weight:500;text-align:center;cursor:pointer;background:#fff;color:var(--text-dark);border-right:1.5px solid rgba(0,0,0,0.14);transition:background .15s,color .15s;user-select:none;border-top:none;border-bottom:none;border-left:none}
.tf-seg:last-child{border-right:none}
.tf-seg.on{background:var(--text-dark);color:#fff}
.tf-seg-sub{font-size:11px;font-weight:400;opacity:.6;display:block;margin-top:1px}
/* Band buttons */
.tf-bands{display:flex;gap:8px;flex-wrap:wrap}
.tf-band{padding:8px 13px;font-size:13px;border:1.5px solid rgba(0,0,0,0.16);border-radius:8px;cursor:pointer;background:#fff;color:var(--text-dark);transition:all .15s;white-space:nowrap}
.tf-band.on{background:var(--text-dark);color:#fff;border-color:var(--text-dark)}
.tf-band:hover:not(.on){border-color:rgba(0,0,0,0.35)}
/* Config summary */
.tf-summary{background:#f5f5f7;border-radius:14px;padding:14px 18px;margin-bottom:20px}
.tf-sum-title{font-size:14px;font-weight:600;color:var(--text-dark);margin-bottom:3px}
.tf-sum-detail{font-size:13px;color:var(--text-muted);line-height:1.6}
/* CTAs */
.tf-addbag{display:block;width:100%;padding:16px;background:var(--blue);color:#fff;border:none;border-radius:14px;font-size:17px;font-family:var(--font);cursor:pointer;text-align:center;text-decoration:none;transition:background .2s;margin-bottom:12px}
.tf-addbag:hover{background:var(--blue-hover)}
.tf-applepay{width:100%;padding:14px;background:#000;color:#fff;border:none;border-radius:14px;font-size:15px;font-family:var(--font);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:opacity .2s;margin-bottom:20px}
.tf-applepay:hover{opacity:.82}
/* Trust */
.tf-trust{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.tf-trust-row{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text-dark)}
.tf-trust-ico{font-size:15px;width:22px;flex-shrink:0}
/* AppleCare */
.tf-ac{border:1.5px solid rgba(0,0,0,0.14);border-radius:14px;padding:16px;display:flex;gap:12px;cursor:pointer;transition:border-color .2s;margin-bottom:14px;background:none;width:100%;text-align:left}
.tf-ac:hover{border-color:rgba(0,0,0,0.3)}
.tf-ac-tick{width:20px;min-width:20px;height:20px;border:1.5px solid rgba(0,0,0,0.25);border-radius:5px;margin-top:1px;display:flex;align-items:center;justify-content:center;font-size:12px;transition:background .15s,border-color .15s}
.tf-ac.on .tf-ac-tick{background:var(--blue);border-color:var(--blue);color:#fff}
.tf-ac-text b{font-size:13px;font-weight:600;display:block;margin-bottom:3px}
.tf-ac-text p{font-size:12px;color:var(--text-muted);line-height:1.55}
/* Stock */
.tf-stock{font-size:13px;color:#1a7a3a;font-weight:500;display:flex;align-items:center;gap:6px;margin-top:4px}
.tf-stock-dot{width:8px;height:8px;border-radius:50%;background:#1a7a3a;flex-shrink:0}
/* Mobile/desktop quote swap */
.tf-mobile-quote{display:none;text-align:left;padding:0 16px;margin-bottom:-12px}
.tf-desk-quote{display:block}
@media(max-width:900px){.tf-mobile-quote{display:block}.tf-desk-quote{display:none}}

/* Topfold responsive */
@media(max-width:1168px) and (min-width:901px){.tf-carousel{margin-left:-24px;width:calc(55% + 24px)}}
@media(max-width:900px){.tf-inner{display:flex;flex-direction:column;gap:16px;width:100%}.tf-carousel{position:static;margin-left:0;width:100%;flex:none}.tf-buy{min-width:0;max-width:100%;width:100%;flex:none}}
@media(max-width:540px){.car-copy{font-size:13px;top:14px;left:14px}.tf-segs .tf-seg{padding:9px 8px;font-size:12px}}

