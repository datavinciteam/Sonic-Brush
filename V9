/* ── Hamburger + mobile nav ───────────────────────────── */
.gnav-hamburger{
  display:none;flex-direction:column;justify-content:center;gap:5px;
  width:34px;height:34px;background:none;border:none;cursor:pointer;padding:5px;
  border-radius:8px;flex-shrink:0;transition:background .15s;
}
.gnav-hamburger:hover{background:rgba(0,0,0,0.06)}
.gnav-hamburger span{display:block;height:1.5px;background:var(--text-dark);border-radius:2px;transition:transform .25s,opacity .2s}
.gnav-hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.gnav-hamburger.open span:nth-child(2){opacity:0}
.gnav-hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}
.gnav-mobile{
  display:none;position:fixed;top:52px;left:0;right:0;bottom:0;
  background:#fff;z-index:980;padding:16px 20px 48px;overflow-y:auto;
  border-top:1px solid rgba(0,0,0,0.08);
}
.gnav-mobile.open{display:block}
.gnav-mobile-links{list-style:none;padding:0;margin:0}
.gnav-mobile-links li a{
  display:block;font-size:17px;font-weight:500;color:var(--text-dark);
  text-decoration:none;padding:15px 0;
  border-bottom:1px solid rgba(0,0,0,0.07);transition:color .15s;
}
.gnav-mobile-links li:last-child a{border-bottom:none}
.gnav-mobile-links li a:hover{color:#2250CE}

